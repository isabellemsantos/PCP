# Python
__pycache__/
*.pyc

# Banco de dados (dados reais, não deve ser versionado)
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Backups automáticos
backups/

# Logs do servidor
*.log

# Planilha de dados reais (não deve ser versionada)
dados_pcp.xlsx
dados_pcp_pendente.xlsx
*.tmp.xlsx

# Arquivos temporários do Office
~$*

# Segredos / ambiente local
.env
.venv/

# Backups históricos em zip
HISTÓRICO/*.zip

# Relatórios de análise de migração (gerados sob demanda, podem conter dados reais)
relatorios_migracao/

# Planilhas de importação oficial (dados reais, não deve ser versionada)
importacao/

# Configuração local de regras reais de clientes (nomes reais de clientes,
# aliases e grupos -- nunca versionar). Só o modelo fictício (.example.json)
# é versionado.
config_local/*.json
!config_local/*.example.json

# Referências visuais externas (imagens de layout, mockups) -- só uso local
# de design, nunca versionadas.
referencias/
